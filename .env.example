# Public browser-safe variables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only variables. OpenAI is optional; AI preview is disabled without a key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano

# Server-only Google OAuth foundation. Required only for /settings/integrations.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
INTEGRATIONS_ENCRYPTION_KEY=

# Server-only Web Push. Required only for push notifications.
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:you@example.com

# Optional future scheduler secret for cron-based push processing.
CRON_SECRET=

# Local scripts only. Do not configure these in browser/client code.
DATABASE_URL=
SEED_USER_ID=

# Local E2E tests only. Put real values only in .env.local.
# Use a disposable Supabase Auth user; never commit real credentials.
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
E2E_BASE_URL=
E2E_PORT=3000

# The app does not use SUPABASE_SERVICE_ROLE_KEY.
